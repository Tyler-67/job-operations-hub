# For vercel CLI uploads (a .vercelignore REPLACES .gitignore semantics there):
# exclude what the frontend build doesn't need — internal docs, backend sources,
# env files. Directory patterns are ROOT-ANCHORED (a bare "supabase/" would also
# match src/integrations/supabase/ and break the build). Git-hook builds unaffected.
node_modules
dist
.git
.vercel
.env
.env.*
/CLAUDE.md
/docs/
/supabase/
/scripts/
bun.lockb
.lovable
